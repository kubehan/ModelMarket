---
import '../styles/global.css'
import { config } from '../lib/data'

interface Props {
  title?: string
  description?: string
}
const { title, description } = Astro.props
const pageTitle = title
  ? `${title} | ${config.site.name}`
  : `${config.site.name} - ${config.site.tagline}`
const pageDesc = description || config.site.description
const canonical = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" id="theme-color" content="#05070d" />

  <!-- Google Fonts: Inter + Noto Sans SC + JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet" />

  <!-- 主题初始化（防闪烁） -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('mm-theme');
      if (!t) { t = window.matchMedia('(prefers-color-scheme:light)').matches ? 'light' : 'dark'; }
      document.documentElement.setAttribute('data-theme', t);
      var c = document.getElementById('theme-color');
      if (c) c.content = t === 'light' ? '#f8f9fc' : (t === 'terminal' ? '#0d1117' : '#05070d');
    })();
  </script>
</head>
<body class="min-h-screen relative">
  <!-- 全局背景舞台：grid + 三道极光 -->
  <div class="bg-stage" aria-hidden="true">
    <div class="bg-aurora bg-aurora-1"></div>
    <div class="bg-aurora bg-aurora-2"></div>
    <div class="bg-aurora bg-aurora-3"></div>
  </div>

  <header class="sticky top-0 z-50 backdrop-blur-xl bg-bg-base/60 border-b border-line-1">
    <div class="container-fluid py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <span class="relative inline-flex w-8 h-8 rounded-lg bg-gradient-brand items-center justify-center shadow-glow-violet">
          <span class="text-white font-extrabold text-sm">M</span>
          <span class="absolute -inset-1 rounded-xl bg-gradient-brand opacity-0 blur-md group-hover:opacity-40 transition-opacity"></span>
        </span>
        <div class="leading-tight">
          <div class="font-bold tracking-tight text-fg-1">{config.site.name}</div>
          <div class="text-[10px] uppercase tracking-[0.18em] text-fg-3">AI Plan Compare</div>
        </div>
      </a>
      <nav class="flex items-center gap-1 text-sm">
        <a href="/" class="px-3 py-1.5 rounded-md text-fg-2 hover:text-fg-1 hover:bg-white/5 transition">对比</a>
        <a href="/changelog" class="px-3 py-1.5 rounded-md text-fg-2 hover:text-fg-1 hover:bg-white/5 transition">更新</a>
        <!-- 主题切换 -->
        <button type="button" class="theme-btn ml-2" id="theme-switcher" title="切换主题">
          <svg id="theme-icon-dark" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          <svg id="theme-icon-light" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg id="theme-icon-terminal" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          <span id="theme-label">深色</span>
        </button>
        {config.community.githubUrl && (
          <a href={config.community.githubUrl} target="_blank" rel="noopener"
             class="ml-1 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-fg-2 hover:text-fg-1 border border-line-2 hover:border-line-3 transition">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.04 11.04 0 015.8 0c2.21-1.5 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
            GitHub
          </a>
        )}
      </nav>
    </div>
  </header>

  <main class="relative">
    <slot />
  </main>

  <footer class="mt-24 border-t border-line-1">
    <div class="container-fluid py-10">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-sm">
        <div class="flex items-center gap-2 text-fg-3">
          <span class="inline-block w-6 h-6 rounded-md bg-gradient-brand opacity-80"></span>
          <span>© {new Date().getFullYear()} {config.site.name} · 价格仅供参考，最终以平台官方为准</span>
        </div>
        <div class="flex items-center gap-4 text-fg-3">
          {config.community.feedbackUrl && (
            <a href={config.community.feedbackUrl} target="_blank" rel="noopener" class="hover:text-fg-1 transition">反馈 / 数据贡献</a>
          )}
          {config.community.githubUrl && (
            <a href={config.community.githubUrl} target="_blank" rel="noopener" class="hover:text-fg-1 transition">GitHub</a>
          )}
        </div>
      </div>
    </div>
  </footer>

  <slot name="end" />

  <!-- 主题切换逻辑 -->
  <script>
    const themeMap: Record<string, { label: string; color: string }> = {
      dark:     { label: '深色', color: '#05070d' },
      light:    { label: '浅色', color: '#f8f9fc' },
      terminal: { label: '终端', color: '#0d1117' },
    }

    function getTheme(): string {
      return localStorage.getItem('mm-theme') || (window.matchMedia('(prefers-color-scheme:light)').matches ? 'light' : 'dark')
    }

    function updateThemeUI(t: string) {
      const root = document.documentElement
      root.setAttribute('data-theme', t)
      localStorage.setItem('mm-theme', t)

      const mc = document.getElementById('theme-color')
      if (mc) { const v = themeMap[t] || themeMap.dark; mc.content = v.color }
      const label = document.getElementById('theme-label')
      if (label) { const v = themeMap[t] || themeMap.dark; label.textContent = v.label }
    }

    const themeBtn = document.getElementById('theme-switcher')
    const themes = ['dark', 'light', 'terminal']
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        const cur = getTheme()
        const idx = themes.indexOf(cur)
        const next = themes[(idx + 1) % themes.length]
        updateThemeUI(next)
      })
    }
  </script>
</body>
</html>
