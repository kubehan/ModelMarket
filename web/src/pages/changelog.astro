---
import Base from '../layouts/Base.astro'
import { config } from '../lib/data'
---

<Base title="更新日志" description="ModelMarket 数据与功能更新记录">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
    <div class="mb-12 fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass text-[10px] uppercase tracking-[0.15em] font-bold text-fg-3 mb-4">
        <span class="dot dot-live"></span> Changelog
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-fg-1">
        <span class="text-gradient">更新日志</span>
      </h1>
      <p class="text-sm text-fg-3 mt-2">数据与功能变更记录</p>
    </div>

    <ol class="relative">
      <div class="absolute left-3 top-0 bottom-0 w-px bg-gradient-to-b from-violet-500/40 via-cyan-500/40 to-transparent"></div>
      {config.changelog.map((entry, idx) => (
        <li class={`relative pl-10 pb-10 fade-up ${idx < 3 ? `fade-up-delay-${idx}` : ''}`}>
          <span class="absolute left-2 top-1.5 flex items-center justify-center w-3 h-3 bg-violet-500 rounded-full ring-4 ring-bg-base shadow-glow-violet"></span>
          <time class="font-mono text-sm font-bold text-fg-1">{entry.date}</time>
          <ul class="mt-3 space-y-2 text-sm text-fg-2">
            {entry.items.map(item => (
              <li class="flex gap-2">
                <span class="text-cyan-400 mt-1">▸</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </section>
</Base>
