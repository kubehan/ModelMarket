---
import { plans } from '../lib/data'
import { deriveAll, monogramSVG } from '../lib/derive'
const derived = deriveAll(plans)

const items = plans.map(p => {
  const d = derived.get(p.id)
  return {
    id: p.id,
    name: p.name,
    vendor: p.vendor,
    type: p.type,
    models: p.models,
    tags: p.tags,
    ppm: d?.pricePerMillion ?? null,
    eff: d?.effectiveMonthly ?? null,
    monogram: p.vendorMonogram || p.vendor.slice(0, 2)
  }
})
const itemsJson = JSON.stringify(items)
---
<div id="cmdk-backdrop" class="cmdk-backdrop" aria-hidden="true"></div>
<div id="cmdk" class="cmdk" role="dialog" aria-label="命令面板">
  <div class="p-3 border-b border-line-2">
    <div class="flex items-center gap-3">
      <svg class="text-fg-3" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input
        id="cmdk-input"
        type="text"
        autocomplete="off"
        placeholder="搜索套餐 / 模型 / 平台，或输入 price<100 model:GLM-5.2"
        class="flex-1 bg-transparent text-fg-1 placeholder:text-fg-4 text-sm focus:outline-none"
      />
      <kbd>ESC</kbd>
    </div>
  </div>
  <div id="cmdk-results" class="max-h-[420px] overflow-y-auto py-1">
    <!-- 注入到 JS 渲染 -->
  </div>
  <div class="px-4 py-2 border-t border-line-2 flex items-center gap-3 text-[10px] text-fg-4 font-mono">
    <span><kbd>↑</kbd><kbd>↓</kbd> 导航</span>
    <span><kbd>↵</kbd> 选中</span>
    <span class="text-fg-3 ml-auto">支持 <code>price&lt;100</code> · <code>model:GLM</code> · <code>type:coding</code></span>
  </div>
</div>

<script type="application/json" id="cmdk-data" set:html={itemsJson}></script>
