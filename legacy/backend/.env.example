# Server
SERVER_PORT=8080
GIN_MODE=debug

# Database (sqlite | postgres)
DB_DRIVER=sqlite
DB_DSN=modelmarket.db
# For postgres example:
# DB_DRIVER=postgres
# DB_DSN=host=localhost user=postgres password=postgres dbname=modelmarket port=5432 sslmode=disable

# JWT
JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_HOURS=24

# Encryption (must be 32 bytes, base64-encoded). Leave empty to auto-generate dev key.
ENCRYPTION_KEY=

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Cache
CACHE_TTL_SECONDS=3600

# Vendor API mode (mock | real)
VENDOR_API_MODE=mock

# Logging
LOG_LEVEL=debug
